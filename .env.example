# Copy to .env and fill in values for local development.
# NEVER commit .env to git.

DJANGO_SETTINGS_MODULE=config.settings.local
DJANGO_SECRET_KEY=change-me-to-a-long-random-string

DATABASE_URL=postgres://brandable:brandable@localhost:5432/brandable
REDIS_URL=redis://localhost:6379/0

# JWT key paths (generate with: make gen-dev-keys)
JWT_PRIVATE_KEY_PATH=config/keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=config/keys/jwt_public.pem
JWT_KID=dev-key-1

# gRPC
GRPC_NOTIFICATION_ADDRESS=localhost:50051

# OTel (optional in local dev)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=brandable-content-platform
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

LOG_LEVEL=INFO
