# ---------------------------------------------------------------------------
# Brandable Content Platform — PRODUCTION environment template
#
# Install on the host as /etc/brandable/env (root:brandable, chmod 640); the
# systemd units read it via EnvironmentFile (see ops/systemd/*.service).
# NEVER commit a filled-in copy. Prefer rendering this from a secrets manager
# at deploy time (see docs/ops/secrets.md) over storing secrets on disk.
#
# For local development use the repo-root .env.example instead.
# ---------------------------------------------------------------------------

# --- Core Django -----------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=__CHANGE_ME__generate_a_50_char_random_string
ALLOWED_HOSTS=api.example.com
CORS_ALLOWED_ORIGINS=https://admin.example.com
LOG_LEVEL=INFO

# --- Database / cache ------------------------------------------------------
DATABASE_URL=postgres://brandable:__DB_PASSWORD__@127.0.0.1:5432/brandable
REDIS_URL=redis://127.0.0.1:6379/0

# --- JWT (RS256) -----------------------------------------------------------
# Generate a dedicated production key pair (NOT the dev keys):
#   openssl genrsa -out jwt_private.pem 2048
#   openssl rsa -in jwt_private.pem -pubout -out jwt_public.pem
# Store under /etc/brandable/keys, readable only by the service user.
JWT_PRIVATE_KEY_PATH=/etc/brandable/keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/etc/brandable/keys/jwt_public.pem
JWT_KID=prod-key-1

# --- gRPC sidecars ---------------------------------------------------------
GRPC_NOTIFICATION_ADDRESS=127.0.0.1:50051
GRPC_LIVE_RUNTIME_ADDRESS=127.0.0.1:50053
GRPC_TIMEOUT_SECONDS=3

# --- Feature flags / external integrations ---------------------------------
# Notification gRPC canary (welcome email). Leave false until the service runs.
NOTIFICATION_ENABLED=false

# Payments — keep Stripe in fake mode until a real account is wired.
STRIPE_FAKE_MODE=true
STRIPE_SECRET_KEY=__sk_live_or_test__
STRIPE_PUBLISHABLE_KEY=__pk_live_or_test__
STRIPE_WEBHOOK_SECRET=__whsec___
PAYMENT_ORDER_TTL_SECONDS=1800

# Live — keep the runtime + Ant Media off until the realtime plane is deployed.
LIVE_RUNTIME_ENABLED=false
ANT_MEDIA_ENABLED=false
ANT_MEDIA_BASE_URL=https://live.example.com
ANT_MEDIA_APP=LiveApp

# Economy / commerce tunables (defaults are sane; override only if needed).
# ECONOMY_DAILY_REWARD_MP=10
# COMMERCE_ORDER_TTL_SECONDS=1800
# COMMERCE_PLATFORM_FEE_RATE=0.05

# --- Observability ---------------------------------------------------------
OTEL_ENABLED=true
OTEL_SERVICE_NAME=brandable-django
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317
